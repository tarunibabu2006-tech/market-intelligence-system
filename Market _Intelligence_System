cution_count":8,"outputs":[]},{"cell_type":"markdown","source":["**10. MODEL 2: User-Based Collaborative Filtering**"],"metadata":{"id":"XZD2RWW4oCaV"}},{"cell_type":"code","source":["from sklearn.metrics.pairwise import cosine_similarity\n","\n","user_sim = cosine_similarity(user_item)\n","\n","user_sim_df = pd.DataFrame(user_sim, index=user_item.index, columns=user_item.index)\n","\n","def recommend_user_based(user_id, n=5):\n","    similar_users = user_sim_df[user_id].sort_values(ascending=False)[1:6]\n","    items = user_item.loc[similar_users.index].mean().sort_values(ascending=False)\n","    return items.head(n).index.tolist()"],"metadata":{"id":"shMJAB1ToGYs","executionInfo":{"status":"ok","timestamp":1774187976211,"user_tz":-330,"elapsed":1182,"user":{"displayName":"Taruni","userId":"00227953413719635008"}}},"execution_count":9,"outputs":[]},{"cell_type":"markdown","source":["**11. MODEL 3: Item-Based Collaborative Filtering**"],"metadata":{"id":"3E52ZCrGoM2X"}},{"cell_type":"code","source":["item_sim = cosine_similarity(user_item.T)\n","\n","item_sim_df = pd.DataFrame(item_sim, index=user_item.columns, columns=user_item.columns)\n","\n","def recommend_item_based(user_id, n=5):\n","    user_data = user_item.loc[user_id]\n","    liked_items = user_data[user_data > 0].index\n","\n","    scores = {}\n","\n","    for item in liked_items:\n","        similar_items = item_sim_df[item].sort_values(ascending=False)[1:6]\n","        for sim_item, score in similar_items.items():\n","            if sim_item not in liked_items:\n","                scores[sim_item] = scores.get(sim_item, 0) + score\n","\n","    return sorted(scores, key=scores.get, reverse=True)[:n]"],"metadata":{"id":"WoihIVpAoQyl","executionInfo":{"status":"ok","timestamp":1774187976217,"user_tz":-330,"elapsed":4,"user":{"displayName":"Taruni","userId":"00227953413719635008"}}},"execution_count":10,"outputs":[]},{"cell_type":"markdown","source":["**12. MODEL 4: Content-Based Filtering**"],"metadata":{"